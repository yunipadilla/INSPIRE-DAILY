# Postgres (Supabase project "Inspire Daily", id tpqebxmtxxjjmlezsvej)
# Get from Supabase dashboard: Project Settings -> Database -> Connection string (URI tab)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.tpqebxmtxxjjmlezsvej.supabase.co:5432/postgres

# Auth
# REQUIRED — the server refuses to start without this (no insecure default).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Email (stub until real credentials are supplied)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Inspire Daily <no-reply@inspiringchildren.org>"

# Twilio WhatsApp (stub until real credentials are supplied)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_GROUP_TO=

# External sync webhook (stub until a real endpoint is supplied)
SYNC_ENDPOINT_URL=
